// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MANAGER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  phone    String?
  role     Role   @default(USER)

  session Session[]
  bookings Booking[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  sessionToken String   @unique
  expires      DateTime
  userAgent    String
  ipAddress    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model TourPackage {
  id   String @id @default(uuid())
  slug String @unique

  title       Json
  description Json?
  location    Json
  duration    Json
  capacity    Int @default(0)

  images Json

  facilityScore  Int   @default(3)
  departureScore Int   @default(1)
  durationDays   Int   @default(1)

  rating  Float @default(0)
  reviews Int   @default(0)

  isPublished Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookings  Booking[]
  priceTiers PriceTier[]

  @@map("tour_packages")
}

model GaleryImage {
  id       String @id @default(uuid())
  imageUrl String @db.Text
  title    Json
  category Json

  createdAt DateTime @default(now())

  @@map("gallery_images")
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Testimonial {
  id        String @id @default(uuid())
  name      String
  role      Json?  // { en: string, id: string, ms: string }
  text      Json   // { en: string, id: string, ms: string }
  avatar    String? @db.Text
  rating    Int    @default(5)
  isPublished Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

model Booking {
  id        String        @id @default(uuid())
  name      String
  email     String
  phone     String
  userId    String?
  packageId String?
  tourDate  DateTime?
  pax         Int           @default(1)
  paymentType PaymentType   @default(FULL)
  totalPrice  Decimal       @db.Decimal(12, 2) @default(0)
  amountPaid  Decimal       @db.Decimal(12, 2) @default(0)
  status      BookingStatus @default(PENDING)
  notes     String?       @db.Text
  paymentProof String?    @db.Text
  settlementProof String? @db.Text
  paymentDeadline DateTime?

  user    User?        @relation(fields: [userId], references: [id])
  package TourPackage? @relation(fields: [packageId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bookings")
}

model TopsisCriterion {
  id     String @id @default(uuid())
  code   String @unique // C1, C2, C3, C4
  name   String
  weight Float
  type   String // COST | BENEFIT

  updatedAt DateTime @updatedAt

  @@map("topsis_criteria")
}

model PriceTier {
  id        String      @id @default(uuid())
  packageId String
  minPax    Int
  maxPax    Int
  price         Decimal     @db.Decimal(12, 2)
  originalPrice Decimal?    @db.Decimal(12, 2)

  package   TourPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@map("price_tiers")
}

model BankAccount {
  id            String   @id @default(uuid())
  bankName      String
  accountName   String
  accountNumber String
  imageUrl      String?  @db.Text
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bank_accounts")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  role      String?
  type      String
  title     String
  message   String   @db.Text
  linkUrl   String?
  isRead    Boolean  @default(false)

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([role, isRead])
  @@map("notifications")
}

enum PaymentType {
  DP
  HALF
  FULL
}
